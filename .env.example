# AssemblyAI API key (required for audio transcription and analysis)
# Get your key at: https://www.assemblyai.com/dashboard/signup
ASSEMBLYAI_API_KEY=your_api_key_here

# Session secret for cookie signing (generate a random string)
# If not set, a random secret is generated on each startup (sessions won't persist across restarts)
SESSION_SECRET=your_random_secret_here

# Google Cloud Storage bucket name
GCS_BUCKET=ums-call-archive

# GCS Authentication (set ONE of the following):
# Option 1: Path to service account key JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# Option 2: Inline service account key JSON (useful for cloud deployments)
# GCS_CREDENTIALS={"client_email":"...","private_key":"...","project_id":"..."}

# ─── AI Analysis Provider ─────────────────────────────────────────────
# Controls which AI backend analyzes call transcripts.
# Set AI_PROVIDER to choose explicitly, or leave unset for auto-detection.
# AI_PROVIDER=gemini     (default — Google AI Studio or Vertex AI)
# AI_PROVIDER=bedrock    (AWS Bedrock + Claude — HIPAA-eligible with BAA)

# --- Option 1: Gemini (Google) ---
# Simplest for personal testing with free tier.
# Get a free key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_api_key_here
# Optional: Override model (default: gemini-2.5-flash for AI Studio, gemini-2.0-flash for Vertex AI)
# GEMINI_MODEL=gemini-2.5-flash
#
# For Vertex AI (production): set GEMINI_CREDENTIALS or use GCS_CREDENTIALS above.
# GEMINI_CREDENTIALS={"client_email":"...","private_key":"...","project_id":"..."}

# --- Option 2: AWS Bedrock + Claude (recommended for HIPAA compliance) ---
# Bedrock is HIPAA-eligible under the AWS BAA. No extra setup beyond IAM.
# Pricing: ~$0.002/call with Claude Haiku.
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# Optional: Override model (default: us.anthropic.claude-haiku-4-5-20251001-v1:0)
# BEDROCK_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# User authentication via environment variables
# Format: username:password:role:displayName (comma-separated for multiple users)
# Roles: admin, manager, viewer
AUTH_USERS=admin:YourSecurePassword:admin:Admin User
